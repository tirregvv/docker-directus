### General
HOST="0.0.0.0"
PORT=8055
PUBLIC_URL="https://basic-directus.yourdomain.com"

### Database credentials (host/port/ssl handled by compose)
DB_DATABASE="directus"
DB_USER="directus"
DB_PASSWORD="changeme-strong-password"

### Security
SECRET="changeme-run-openssl-rand-hex-32"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_COOKIE_SAME_SITE="lax"
REFRESH_TOKEN_COOKIE_NAME="directus_refresh_token"
REFRESH_TOKEN_COOKIE_DOMAIN="yourdomain.com"
SESSION_COOKIE_TTL="1d"
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE="lax"
SESSION_COOKIE_NAME="directus_session_token"

### Admin
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="changeme-strong-password"

### Email
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST="smtp.hostname.com"
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER="email_user"
EMAIL_SMTP_PASSWORD="email_password"
EMAIL_SMTP_IGNORE_TLS=true
EMAIL_SMTP_SECURE=true

### Cache (store/redis handled by compose)
CACHE_ENABLED=true
CACHE_TTL="30m"
CACHE_AUTO_PURGE=true
CACHE_AUTO_PURGE_IGNORE_LIST="directus_activity,directus_presets"
ASSETS_CACHE_TTL="30d"
CACHE_STATUS_HEADER=true
CACHE_SKIP_ALLOWED=true

### Storage
STORAGE_LOCATIONS="local"
STORAGE_LOCAL_DRIVER="local"
STORAGE_LOCAL_ROOT="./uploads"

### Extensions
EXTENSIONS_PATH="./extensions"
EXTENSIONS_AUTO_RELOAD=true

### Rate limiting
RATE_LIMITER_ENABLED=false
RATE_LIMITER_STORE=memory
RATE_LIMITER_POINTS=25
RATE_LIMITER_DURATION=1

### CORS
CORS_ENABLED=true
CORS_ORIGIN=true
CORS_METHODS=GET,POST,PATCH,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_EXPOSED_HEADERS=Content-Range
CORS_CREDENTIALS=true
CORS_MAX_AGE=18000

### Auth
AUTH_PROVIDERS=""